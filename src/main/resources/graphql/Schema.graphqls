type Query {
    getAllUsers: [UserResponse!]!
    getUserById(id: ID!): UserResponse
    skills: [Skill!]!
}

type UserResponse {
    id: ID!
    name: String
    role: String
    email: String
    location: String
    bio: String
    githubUrl: String
    linkedinUrl: String
    createdAt: String
    updatedAt: String
}

type Skill {
  id: ID!
  name: String!
  category: String!
  createdAt: String
  deleted: Boolean
}

enum SkillCategory {
  Frontend
  Backend
  Database
  Other
}